# Copy this file to .env (for local use) or paste these into
# Railway's "Variables" tab (for hosting).
#
# When set, these override the matching values in database/config.json,
# so the bot token never has to live in a committed file.

# Your Discord bot token (Developer Portal -> Bot -> Reset Token)
TOKEN=

# Your bot's application/client ID (Developer Portal -> General Information)
CLIENTID=

# Your own Discord user ID (enables owner-only commands)
OWNER=
